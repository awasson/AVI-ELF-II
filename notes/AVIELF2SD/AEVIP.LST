0234   0000             ;
0235   0000             ;
0236   0000             ;            [<label>] .TEXT   "<string>"
0237   0000             ;
0238   0000             ;            Escape
0239   0000             ;            Sequence        Description
0240   0000             ;            ------------------------------
0241   0000             ;            \n              Line Feed
0242   0000             ;            \r              Carriage return
0243   0000             ;            \b              Backspace
0244   0000             ;            \t              Tab
