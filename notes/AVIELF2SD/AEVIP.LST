0254   0000             ;
0255   0000             ;	RAM
0256   0000             ;7E00	Video Display Page
0257   0000             ;7F7F	Stack
0258   0000             ;
0259   0000             ;
0260   0000             ; register usage
0261   0000             ;
0262   0000             ;	R0 = 1861 video DMA pointer
0263   0000             ;	R1 = 1861 interrupt handler PC
0264   0000             ;	R2 = stack pointer
0265   0000             ;	R3 = main PC
0266   0000             ;	R4 = call subroutine PC   (SCRT)
0267   0000             ;	R5 = return subroutine PC (SCRT)
0268   0000             ;	R6 = return address       (SCRT)
0269   0000             ;	R7 = 
0270   0000             ;	R8 = 
0271   0000             ;	R9 = High is system STATUS, Low is PC_POS
0272   0000             ;	RA = scratch
0273   0000             ;	RB = scratch
0274   0000             ;	RC = Cursor position (Line/Pixel Position)
0275   0000             ;	RD = scratch, Display pointer during Screen PRINT
0276   0000             ;	RE = scratch
0277   0000             ;	RF = scratch, HIGH saves D during CALL/RET (SCRT)
0278   0000             ;
0279   0000             ;
0280   0000             ;	R9.1 = STATUS
0281   0000             ;	bit0 	PIXIE PRESENT (Cleared if Serial Interface selected)
0282   0000             ;	bit1	Cursor Enable
0283   0000             ;	bit2	Set if RAM good
0284   0000             ;	bit3	not used
0285   0000             ;	bit4	SD Card Inserted
0286   0000             ;	bit5	Set to use FILE BLOCK MODE (process entire sector vs byte)
0287   0000             ;	bit6	Set if ELF Keyboard detected, 
0288   0000             ;		used for boot up display and Menu Type Selection
0289   0000             ;	bit7	Set if VIP Keyboard detected
0290   0000             ;		used for boot up display and Menu Type Selection
0291   0000             ;		and used in RXChar to selecttype of Keyboard to read
0292   0000             
0293   0000             
0294   0000             
0295   0000             	.MSFIRST	;when using .dw, save Most significant byte first (Big Endian)
0296   0000             	.NOPAGE
0297   0000             	
0298   0000             	.ORG	0000h
0299   0000             
0300   0000 90          		GHI	R0	;Set page of subroutines
0301   0001 B1          		PHI	R1	;
0302   0002 B4          		PHI	R4
0303   0003 B5          		PHI	R5
0304   0004 B9          		PHI	R9	;Clear system status
0305   0005 F8 1B       		LDI	ISR%256
0306   0007 A1          		PLO	R1		;R1 = 1861 interrupt handler
0307   0008             
0308   0008 F8 FE       		LDI	0FEh	;R2 = FEFEh STACK
0309   000A B2          		PHI	R2
0310   000B A2          		PLO	R2
0311   000C             
0312   000C F8 39       		LDI	CALLR%256
0313   000E A4          		PLO	R4
0314   000F F8 4C       		LDI	RETNR%256
0315   0011 A5          		PLO	R5
0316   0012             
