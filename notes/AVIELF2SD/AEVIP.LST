0182+  7EC2             ;
0183+  7EC2             ; tread -- tape read command
0184+  7EC2             ;
0185+  7EC2             tread:
0186+  7EC2 F8 83               ldi tapein%256  ;change RC to point to tapein
0187+  7EC4 AC                  plo rc          ;  subroutine to read 1 bit
0188+  7EC5             tread1:			;Lead In Loop
0189+  7EC5 F8 0A               ldi 10
0190+  7EC7 B9                  phi r9
0191+  7EC8             tread2:
0192+  7EC8 DC                  sep rc          ;call TapeIn to read 1 bit
0193+  7EC9             
0194+  7EC9 33 C5               bdf tread1	;Loop back while 1 (Lead IN)
0195+  7ECB 29                  dec r9
0196+  7ECC 99                  ghi r9
0197+  7ECD 3A C8               bnz tread2
0198+  7ECF             tread5:
0199+  7ECF DC                  sep rc          ;call TapeIn to read 1 bit
0200+  7ED0 3B CF               bnf tread5	;Loop back until we get START BIT (1)
0201+  7ED2 F8 09               ldi 9
0202+  7ED4 A9                  plo 9		;Set Bit Counter
0203+  7ED5 A7                  plo 7		;Set Parity Counter
0204+  7ED6             tread3:
0205+  7ED6 97                  ghi r7		;Get Byte to assemble
0206+  7ED7 76                  shrc		;Shift in READ bit
0207+  7ED8 B7                  phi r7		;Save Byte
0208+  7ED9 29                  dec r9		;Count bits
