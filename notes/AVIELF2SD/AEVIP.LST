0322   0019             
0323   0019             ;**********************************************************************
0324   0019             ;**********************************************************************
0325   0019             ;**               SCRT Subroutines and ISR                           **
0326   0019             ;** Interrupt:  X,P->T, 2->X, 1->P, 0->IE                            **
0327   0019             ;**********************************************************************
0328   0019             ;**********************************************************************
0329   0019             
0330   0019             ; interrupt routine for 64x32 format (1 page display memory)
0331   0019             ;
0332   0019 42          INTRET:		LDA R2
0333   001A 70          		RET		;<-return with interrupts enabled
0334   001B             ISR:                    ;->entry with P=R1
0335   001B 22          		DEC R2		;point to free location on stack
0336   001C 78          		SAV		;  push T
0337   001D 22          		DEC R2
0338   001E 52          		STR R2		;  save D
0339   001F C4          		NOP		;3 cycles of NOP for sync
0340   0020             
0341   0020 F8 00       		LDI	0	;reset DMA pointer to start of
0342   0022 A0          		PLO	R0	;  display RAM
0343   0023 F8 FF       		LDI	VIDEO_PAGE/256
0344   0025 B0          		PHI	R0
0345   0026 40          		LDA	R0	;Cannot use LDN R0, that is IDLE command
0346   0027 B0          		PHI	R0
0347   0028 20          		DEC	R0
0348   0029             
0349   0029             				;set D=line start address (6 cycles)
0350   0029             ISRDISP:                                           
0351   0029 80          		GLO R0
0352   002A             				;1861 displays a line (8 cycles)
0353   002A E2          		SEX R2
0354   002B E2          		SEX R2		;reset line start address (6 cycles)
0355   002C 20          		DEC R0
0356   002D             				;1861 displays line a 2nd time (8 cycles)
0357   002D A0          		PLO R0
0358   002E E2          		SEX R2		;reset line start address (6 cycles)
0359   002F 20          		DEC R0
0360   0030             				;1861 displays line a 3rd time (8 cycles)
0361   0030 A0          		PLO R0
0362   0031 E2          		SEX R2		;reset line start address (6 cycles)
0363   0032 20          		DEC R0
0364   0033             				;1861 displays line a 4th time (8 cycles)
0365   0033 A0          		PLO R0		;set R0.0=line start address
0366   0034 3C 29       		BN1 ISRDISP	;loop 32 times
0367   0036 30 19               	BR  INTRET
0368   0038             
0369   0038             
0370   0038             
0371   0038             ;**********************************************************************
0372   0038             ;Call Subroutine SCRT
0373   0038             ;call with R2 pointing to free stack byte
0374   0038             ;Pushes R6 to Stack
0375   0038             ;Sets R6 to Return Address (2 bytes after Sep R4 call)
0376   0038             ;Returns execution to R3
0377   0038             ;----------------------------------------------------------------------
0378   0038 D3          	SEP R3	;go to called program
0379   0039 BF          CALLR:	PHI RF	;Save D
0380   003A E2          	SEX R2	;X=Stack
0381   003B 22          	DEC R2  ;Point to free byte on stack
0382   003C 86          	GLO R6	;Push r6 to Stack, big endian
0383   003D 73          	STXD
0384   003E 96          	GHI R6
0385   003F 73          	STXD
0386   0040 83          	GLO R3	;Fetch Unmodified Return Address
0387   0041 A6          	PLO R6
0388   0042 93          	GHI R3
0389   0043 B6          	PHI R6
0390   0044 46          	LDA R6	;get subroutine address AND modify return address
0391   0045 B3          	PHI R3	;to skip inline data
0392   0046 46          	LDA R6	;save call to address to R3
0393   0047 A3          	PLO R3
0394   0048 9F          	GHI RF	;restore D
0395   0049 30 38       	BR  CALLR-1	;jump for SEP R4 re-entery
0396   004B             
0397   004B             
0398   004B             ;**********************************************************************
0399   004B             ;Return Subroutine SCRT
0400   004B             ;Call with R2 pointing to free stack byte below return address
0401   004B             ;Restores Return Address in R6 to R3
0402   004B             ;Pops R6 from stack
0403   004B             ;Returns execution to R3
0404   004B             ;----------------------------------------------------------------------
0405   004B D3          	SEP R3	;go to calling program
0406   004C BF          RETNR:	PHI RF	;Save D
0407   004D 96          	GHI R6	;Fetch Return Address
0408   004E B3          	PHI R3	;back to R3
0409   004F 86          	GLO R6
0410   0050 A3          	PLO R3
0411   0051 12          	INC R2	;Pop previous R6 from stack
0412   0052 42          	LDA R2
0413   0053 B6          	PHI R6	;
0414   0054 E2          	SEX R2	;X=Stack
0415   0055 42          	LDA R2
0416   0056 A6          	PLO R6	;
0417   0057 9F          	GHI RF	;restore D
0418   0058 30 4B       	BR  RETNR-1
0419   005A             
