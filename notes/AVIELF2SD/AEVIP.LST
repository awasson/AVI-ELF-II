0109+  7E71 DC                  sep rc          ;wait until C key released
0110+  7E72 D7                  sep r7          ;  get 1st key
0111+  7E73 D7                  sep r7          ;  go back to get byte to shift and get 2nd key
0112+  7E74 D7                  sep r7          ;  go back to get byte to OR the hex digits
0113+  7E75 B6                  phi r6          ;save in R6.1
0114+  7E76 D7                  sep r7          ;  get 1st key
0115+  7E77 D7                  sep r7          ;  go back to get byte to shift and get 2nd key
0116+  7E78 D7                  sep r7          ;  go back to get byte to OR the hex digits
0117+  7E79 A6                  plo r6          ;save in R6.0
0118+  7E7A D4                  sep r4          ;display address R6, and M(R6)
0119+  7E7B DC                  sep rc          ;get a key
0120+  7E7C BE                  phi re          ;  save it
0121+  7E7D 32 F4               bz  mwrite      ;if "0", go to Memory Write command
0122+  7E7F FB 0A               xri 10
0123+  7E81 32 EF               bz  mread       ;if "A", go to Memory Read command
0124+  7E83 DC                  sep rc          ;get a key (count of pages to write/read to tape)
0125+  7E84 AE                  plo re          ;  save it
0126+  7E85 22                  dec r2
0127+  7E86 61                  out 1           ;turn off TV
0128+  7E87 9E                  ghi re          ;get saved key
