0131+  7E8C 9E                  ghi re          ;get saved key
0132+  7E8D FB 0F               xri 0Fh         ;if anything but "F",
0133+  7E8F 3A 8F               bnz $           ;  loop forever
0134+  7E91             ;
0135+  7E91             ; twrite -- tape write command
0136+  7E91             ;
0137+  7E91 F8 6F               ldi beep%256    ;change RC to point to Beep subroutine
0138+  7E93 AC                  plo rc
0139+  7E94 F8 40               ldi 40h		;write lead in 0x40xx bits (~16,000 bits)
0140+  7E96 B9                  phi r9
0141+  7E97             
0142+  7E97             twrite:			;write lead in loop
0143+  7E97 93                  ghi r3		;r3 = PC = 0x8098
0144+  7E98 F6                  shr		;aka Clear DF flag Send "0"
0145+  7E99 DC                  sep rc          ;call Beep to write 0 bit
0146+  7E9A 29                  dec r9
0147+  7E9B 99                  ghi r9
0148+  7E9C 3A 97               bnz twrite	;Loop ~16,000 times
0149+  7E9E             twrite1:
0150+  7E9E F8 10               ldi 10h		;Reset Parity Counter (Counts 1's sent)
0151+  7EA0 A7                  plo r7
0152+  7EA1 F8 08               ldi 8
0153+  7EA3 A9                  plo r9
0154+  7EA4 46                  lda r6		;Get byte to write to Tape
0155+  7EA5 B7                  phi r7		;Hold Byte in R7.1
0156+  7EA6 93                  ghi r3
0157+  7EA7 FE                  shl		;Send "1"
0158+  7EA8 DC                  sep rc          ;call Beep to write a 1 bit             -SEND START BIT (1)
0159+  7EA9 86                  glo r6		;Check for page boundary
0160+  7EAA 3A AD               bnz twrite2
0161+  7EAC 2E                  dec re		;count down pages writen on every page boundary
0162+  7EAD             twrite2:
0163+  7EAD 97                  ghi r7		;Fetch Byte to write
0164+  7EAE F6                  shr		;Shift out bit
0165+  7EAF B7                  phi r7
0166+  7EB0 DC                  sep rc          ;call Beep to write a data bit          -SEND 8 DATA BITS
0167+  7EB1 29                  dec r9		;decrement bit counter
0168+  7EB2 89                  glo r9
0169+  7EB3 3A AD               bnz twrite2	;loop back to write 8 bits
0170+  7EB5 17                  inc r7		;Calculate EVEN Parity
0171+  7EB6 87                  glo r7
0172+  7EB7 F6                  shr
0173+  7EB8 DC                  sep rc          ;call Beep to write parity bit          -SEND PARITY BIT          
0174+  7EB9 8E                  glo re
0175+  7EBA 3A 9E               bnz twrite1	;loop back to write next byte until all pages are written
0176+  7EBC DC                  sep rc          ;call Beep to write FINAL bit
