0001+  7E00             	;AE VIP ROM
0002+  7E00             	;.org	8000h
0003+  7E00 F8 80       VIPROM  ldi 80h		;set R2=8008     ;this code is found at XVipRom
0004+  7E02 B2                  phi r2
0005+  7E03 F8 08               ldi here1%256
0006+  7E05 A2                  plo r2
0007+  7E06 E2                  sex r2
0008+  7E07 D2                  sep r2          ;make R2 the program counter
0009+  7E08             
0010+  7E08 64          here1:  out 4           ;reset address inhibit latch (map RAM to 0000 area)
0011+  7E09 00                  .db  0
0012+  7E0A 62                  out 2           ;set keyboard latch to monitor "C" Key
0013+  7E0B 0C                  .db  0Ch
0014+  7E0C F8 FF               ldi 0FFh        ;test for high end of RAM
0015+  7E0E A1                  plo r1
0016+  7E0F F8 0F               ldi 0Fh
0017+  7E11 B1                  phi r1          ;set R1=0FFF (4k; max RAM on VIP)
0018+  7E12 F8 AA       notram: ldi 0AAh        ;store AA
0019+  7E14 51                  str r1
0020+  7E15 01                  ldn r1          ;load it
0021+  7E16 FB AA               xri 0AAh        ;if it worked,
0022+  7E18 32 22               bz  isram       ;  then R1 points to top of RAM
0023+  7E1A 91                  ghi r1
0024+  7E1B FF 04               smi 4           ;else R1=R1-0400 (try 1k lower)
0025+  7E1D 3B 22               bnf isram       ;if underflow, no RAM, continue anyway
0026+  7E1F B1                  phi r1
0027+  7E20 30 12               br  notram      ;if not 4k of RAM, then try 1k lower
0028+  7E22 36 28       isram:  b3  monitor	;if "C" key is not pressed,
0029+  7E24 90                  ghi r0          ;  set R0=0000
0030+  7E25 A0                  plo r0
0031+  7E26 E0                  sex r0          ;  set X=0, P=0,
0032+  7E27 D0                  sep r0          ;  and go execute program at 0
0033+  7E28                     		;  R1=Last byte of RAM available (0FFF,0CFF,08FF or 04FF) (0FFF on VElf)
0034+  7E28 E1          monitor: sex r1
0035+  7E29             clear10:                ;clear RAM from top=0xFF to 0xB0 of last page of ram (0FFF to 0FB0 on VElf)
0036+  7E29 F8 00               ldi 0           ;  clear a byte
0037+  7E2B 73                  stxd            ;  decrement pointer
0038+  7E2C 81                  glo r1
0039+  7E2D FB AF               xri 0AFh        ;  until address=0xAF
0040+  7E2F 3A 29               bnz clear10
