1477   0BF9             ;**********************************************************************
1478   0BF9             ;
1479   0BF9             ;    Intel Hex Object Format. This is the default format.  This format is
1480   0BF9             ;    line  oriented  and  uses only printable ASCII characters except for
1481   0BF9             ;    the carriage return/line feed at the end of each line.  Each line in
1482   0BF9             ;    the file assumes the following format:
1483   0BF9             ;
1484   0BF9             ;    :NNAAAARRHHHHHHHHHHHHHHHHHHHHHHHHHHHHHHHHHHHHHHHHHHHHHHHHCCTT
1485   0BF9             ;
1486   0BF9             ;    Where:
1487   0BF9             ;
1488   0BF9             ;    All fields marked 'hex' consist of two  or  four  ASCII  hexadecimal
1489   0BF9             ;    digits  (0-9,  A-F).  A maximum of 24 data bytes will be represented
1490   0BF9             ;    on each line.
1491   0BF9             ;
1492   0BF9             ;    :       = Record Start Character
1493   0BF9             ;    NN      = Byte Count (hex)
1494   0BF9             ;    AAAA    = Address of first byte (hex)
1495   0BF9             ;    RR      = Record Type (hex, 00 except for last record which is 01)
1496   0BF9             ;    HH      = Data Bytes (hex)
1497   0BF9             ;    CC      = Check Sum (hex)
1498   0BF9             ;    TT      = Line Terminator (carriage return, line feed)
1499   0BF9             ;
1500   0BF9             ;    The last line of the file will be a record conforming to  the  above
1501   0BF9             ;    format with a byte count of zero (':00000001FF').
1502   0BF9             ;
1503   0BF9             ;    The checksum is defined as:
1504   0BF9             ;
1505   0BF9             ;            sum      =  byte_count + address_hi + address_lo +
1506   0BF9             ;                            record_type + (sum of all data bytes)
1507   0BF9             ;            checksum =  ((-sum) & ffh)
1508   0BF9             ;
1509   0BF9             ;	RR=05, Start Linear Address address aaaa in big endian
1510   0BF9             ;		:040000050000aaaaCC
1511   0BF9             ;
1512   0BF9             ;Input byte @RD
1513   0BF9             ;Uses registers R7, R8, RA, RB,
1514   0C00             		NEWPAGE
1515   0C00             WRITE_HEX	
1516   0C00 8C          WH_SEND512	GLO	RC
1517   0C01 3A 06       		BNZ	WH_1
1518   0C03 9C          		GHI	RC
1519   0C04 32 0F       		BZ	WH_EX		;EXIT IF EOF
1520   0C06 2C          WH_1		DEC	RC
1521   0C07             					;
1522   0C07 88          		GLO	R8
1523   0C08 A3          		PLO	R3	;Branch to step
