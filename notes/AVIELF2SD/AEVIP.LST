0001+  0092             
0002+  0092             ;TEST RAM.  Write sequence, read sequence
0003+  0092             ;Sequence is 0 to X, where X is 3, then increments by 4
0004+  0092             ;This will hit 29 primes 3, 7, 11, 19, 23, 31, 43, 47, 59, 67, 71, 79, 83, 103,
0005+  0092             ;107, 127, 131, 139, 151, 163, 167, 179, 191, 199, 211, 223, 227, 239, 251
0006+  0092             ;
0007+  0092             ;Sequence is 0 to X, where X is 179, then increments by 24
0008+  0092             ;This will hit 3 prime numbers
0009+  0092             ;
0010+  0092             ;RAM 6000 - 7FFF
0011+  0092             
0012+  0092 EA          		SEX	RA
0013+  0093             		
0014+  0093             ;DEBUG		LDI	179
0015+  0093             				;251 252 253 254 255
0016+  0093 F8 FB       		LDI	251	;=FB  FC  FD  FE  FF
0017+  0095 AC          RT_TT_LOOP	PLO	RC	;X = 3, This is the count of the sequence
0018+  0096 AB          		PLO	RB	;Save count to Counter
0019+  0097             
0020+  0097 F8 C0       		LDI	0C0h	;RA = C000, points to RAM to test
0021+  0099 BA          		PHI	RA
0022+  009A F8 00       		LDI	000h
0023+  009C AA          		PLO	RA
0024+  009D             
0025+  009D 2B          RT_SV_LOOP	DEC	RB	;Decrement counter
0026+  009E 8B          		GLO	RB
0027+  009F 5A          		STR	RA	;Store in RAM and Decrement.
0028+  00A0 3A A4       		BNZ	RT_SV_DO
0029+  00A2 8C          		GLO	RC
0030+  00A3 AB          		PLO	RB
0031+  00A4 1A          RT_SV_DO	INC	RA	
0032+  00A5 9A          		GHI	RA	;Test for FFFF
0033+  00A6 FC 01       		ADI	1
0034+  00A8 3A 9D       		BNZ	RT_SV_LOOP
0035+  00AA 8A          		GLO	RA	;Test for FFFF
0036+  00AB FC 01       		ADI	1
0037+  00AD 3A 9D       		BNZ	RT_SV_LOOP
0038+  00AF             
0039+  00AF F8 C0       		LDI	0C0h	;RA = C000, points to RAM to test
0040+  00B1 BA          		PHI	RA
0041+  00B2 F8 00       		LDI	000h
0042+  00B4 AA          		PLO	RA
0043+  00B5             
0044+  00B5 8C          		GLO	RC
0045+  00B6 AB          		PLO	RB	;Save count to Counter
0046+  00B7             		
0047+  00B7 2B          RT_CH_LOOP	DEC	RB	;Decrement counter
0048+  00B8 8B          		GLO	RB
0049+  00B9 F3          		XOR		;Test against RAM
0050+  00BA 3A F2       		BNZ	RT_BAD
0051+  00BC F3          		XOR		;Restore byte with 2nd XOR
0052+  00BD 3A C1       		BNZ	RT_CH_DO
0053+  00BF 8C          		GLO	RC
0054+  00C0 AB          		PLO	RB
0055+  00C1 1A          RT_CH_DO	INC	RA	
0056+  00C2 9A          		GHI	RA	;Test for FFFF
0057+  00C3 FC 01       		ADI	1
0058+  00C5 3A B7       		BNZ	RT_CH_LOOP
0059+  00C7 8A          		GLO	RA	;Test for FFFF
0060+  00C8 FC 01       		ADI	1
0061+  00CA 3A B7       		BNZ	RT_CH_LOOP
0062+  00CC             	
0063+  00CC 8C          		GLO	RC
0064+  00CD FC 18       		ADI	24
0065+  00CF 3B 95       		BNF	RT_TT_LOOP		
0066+  00D1             
0067+  00D1             				;Final test, write ff, then 00 and verify
0068+  00D1             		
0069+  00D1 F8 C0       		LDI	0C0h	;RA = C000h
0070+  00D3 BA          		PHI	RA
0071+  00D4 F8 00       		LDI	00h
0072+  00D6 AA          		PLO	RA
0073+  00D7             
0074+  00D7 F8 FF       RT_CLR_LOOP	LDI	0FFh
0075+  00D9 5A          		STR	RA
0076+  00DA F3          		XOR
0077+  00DB 3A F2       		BNZ	RT_BAD
0078+  00DD F8 00       		LDI	0
0079+  00DF 5A          		STR	RA
0080+  00E0 F3          		XOR
0081+  00E1 3A F2       		BNZ	RT_BAD
0082+  00E3             		
0083+  00E3 1A          		INC	RA
0084+  00E4 9A          		GHI	RA	;Test for FFFF
0085+  00E5 FC 01       		ADI	1
0086+  00E7 3A D7       		BNZ	RT_CLR_LOOP
0087+  00E9 8A          		GLO	RA	;Test for FFFF
0088+  00EA FC 01       		ADI	1
0089+  00EC 3A D7       		BNZ	RT_CLR_LOOP
0090+  00EE             		
0091+  00EE 99          		GHI	R9
0092+  00EF F9 04       		ORI	4	;MARK GOOD RAM
0093+  00F1 B9          		PHI	R9
0094+  00F2             		
