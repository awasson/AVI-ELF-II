0432   0061             ;-------------------------------------------------------------------- KEYPAD TESTING
0433   0061             				; IF VIP Keypad present THEN
0434   0061             				;    IF VIP Keypad C pressed THEN 
0435   0061             				;       Say "Running VIP"
0436   0061             				;       Load VIP to 8000 and RUN it
0437   0061             				;    END IF
0438   0061             				; END IF
0439   0061 E3          		SEX	R3
0440   0062 62          		OUT	2	;Select a key that isn't likely to be pressed
0441   0063 07          		.DB	07h	;Test key 7 (Not Key C)
0442   0064 65          		OUT	5
0443   0065 20          		.DB	20h	;001 = Enable x45 sensing
0444   0066 65          		OUT	5
0445   0067 10          		.DB	10h	;
0446   0068 65          		OUT	5
0447   0069 01          		.DB	01h	;
0448   006A             
0449   006A 3F 7A       		BN4	TVK_END	;Jump no VIP Keyboard
0450   006C             				
0451   006C 65          		OUT	5	;CONTROL BYTE = No Test, EF4=free
0452   006D 00          		.DB	00h	;000 = Disable x45 sensing
0453   006E             
0454   006E 36 7A       		B3	TVK_END	;Jump if EF3 low
0455   0070             
0456   0070 62          		OUT	2	;
0457   0071 0C          		.DB	0Ch	;Test for key C
0458   0072 F8 80       		LDI	80h	;STATUS = VIP KEYPAD PRESENT
0459   0074 B9          		PHI	R9
0460   0075 3E 85       		BN3	TK_END	;C not pressed
0461   0077             
0462   0077 C0 13 FD    		LBR	GOVIP	;Copy VIP to ROM @ 8000, Jump!
0463   007A             		
0464   007A 65          TVK_END		OUT	5	;CONTROL BYTE = No Test, EF3=free
0465   007B 11          		.DB	11h	;010 = Map 74C923 to /EF4
0466   007C             				;Test for ELF Keyboard (74C923) Present
0467   007C             				;
0468   007C 7A          		REQ		;Pull line high (Q is inverted)
0469   007D 37 82       		B4	TEK_OK	;Jump if line is LOW (doesn't pull high, C923 holds it low)
0470   007F 7B          		SEQ		;Pull line low to test if C923 holds it high (key pressed)
0471   0080 37 85       		B4	TK_END
